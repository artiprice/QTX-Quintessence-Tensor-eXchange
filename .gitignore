# third_party/ggml_src is a git submodule (full ggml repo, ~23 MB) —
# needed only for the optional real-ggml demo. Clone with --recursive,
# or run: git submodule update --init --depth 1
# The small third_party/ggml/ (headers + shim, ~180 KB) is committed
# directly so the test suite builds WITHOUT the submodule.
